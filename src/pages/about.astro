---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Timeline from '../components/Timeline.astro';
import SkillTags from '../components/SkillTags.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="About — EE Heng Chen">
  <PageHeader
    title="About"
    subtitle="Part-time coder and computer-vision researcher, now working on AI agents."
    volume="02"
  />

  <section class="mb-10 flex flex-col sm:flex-row items-start gap-6">
    <img
      src={base + '/assets/images/cropped-head-388.jpg'}
      alt="Chen Ee Heng"
      width="160"
      height="160"
      class="rounded-full border border-zinc-200 dark:border-zinc-800 shrink-0"
    />
    <div class="text-zinc-700 dark:text-zinc-300 leading-relaxed">
      <p>
        I'm Chen Ee Heng — based in Munich, Germany. I spent several years on
        computer-vision research (traffic-junction perception, optical flow, binary
        neural networks, patient-monitoring models) and am now focused on AI agents
        that edit code with discipline.
      </p>
    </div>
  </section>

  <Timeline />
  <SkillTags />
</Layout>
