---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionPreview from '../components/SectionPreview.astro';
import PublicationCard from '../components/PublicationCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { publications } from '../data/publications';
import { projects } from '../data/projects';

const recentPublications = [...publications]
  .sort((a, b) => b.year - a.year)
  .slice(0, 2);

const activeProjects = projects.filter((p) => p.status === 'active').slice(0, 2);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="EE Heng Chen">
  <Hero />

  <SectionPreview index="01" eyebrow="Selected papers" title="Research" href="/research">
    {recentPublications.map((p) => <PublicationCard publication={p} />)}
  </SectionPreview>

  <SectionPreview index="02" eyebrow="What I'm shipping" title="Projects" href="/projects">
    {activeProjects.map((p) => <ProjectCard project={p} />)}
  </SectionPreview>

  <section class="mt-16">
    <div class="flex items-end justify-between gap-4 border-b border-zinc-200 dark:border-zinc-800 pb-3">
      <div class="flex items-baseline gap-3">
        <span class="text-xs font-mono font-medium text-zinc-400 dark:text-zinc-500 tabular-nums">03</span>
        <div>
          <div class="text-[11px] uppercase tracking-[0.16em] text-zinc-500 dark:text-zinc-400">Currently</div>
          <h2 class="text-2xl font-semibold tracking-tight">Now</h2>
        </div>
      </div>
      <a
        href={base + '/now'}
        class="group inline-flex items-center gap-1 text-sm font-medium text-zinc-600 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-50"
      >
        Full update
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
      </a>
    </div>

    <article class="mt-6 relative overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800 bg-gradient-to-br from-white via-white to-indigo-50/40 dark:from-zinc-950 dark:via-zinc-950 dark:to-indigo-950/30 p-6 sm:p-7">
      <div class="absolute -top-16 -right-16 h-48 w-48 rounded-full bg-fuchsia-300/20 blur-3xl dark:bg-fuchsia-500/15 pointer-events-none" aria-hidden="true"></div>
      <p class="text-base sm:text-lg text-zinc-800 dark:text-zinc-200 leading-relaxed">
        Coming from computer-vision research, currently building AI agents that
        edit code with discipline. On the side: agent-evaluation papers and
        short notes on the tools I use day-to-day.
      </p>
      <a
        href={base + '/now'}
        class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-indigo-600 dark:text-indigo-300 hover:text-indigo-700 dark:hover:text-indigo-200 group"
      >
        Read the full /now page
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
      </a>
    </article>
  </section>
</Layout>
