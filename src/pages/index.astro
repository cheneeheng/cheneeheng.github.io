---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionPreview from '../components/SectionPreview.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const otherProjects = projects.slice(1, 3);
---

<Layout title="EE Heng Chen">
  <Hero />

  <SectionPreview eyebrow="In parallel & shipped" title="Other work" href="/projects">
    {otherProjects.map((p) => <ProjectCard project={p} />)}
  </SectionPreview>
</Layout>
