---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionPreview from '../components/SectionPreview.astro';
import PublicationCard from '../components/PublicationCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { publications } from '../data/publications';
import { projects } from '../data/projects';

const recentPublications = [...publications]
  .sort((a, b) => b.year - a.year)
  .slice(0, 2);

const activeProjects = projects.filter((p) => p.status === 'active').slice(0, 2);
---

<Layout title="EE Heng Chen">
  <Hero />

  <SectionPreview title="Research" href="/research">
    {recentPublications.map((p) => <PublicationCard publication={p} />)}
  </SectionPreview>

  <SectionPreview title="Projects" href="/projects">
    {activeProjects.map((p) => <ProjectCard project={p} />)}
  </SectionPreview>

  <SectionPreview title="Now" href="/now">
    <p class="text-zinc-700 dark:text-zinc-300">
      Building AI agents that edit code with discipline. See the
      <a class="underline" href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/now'}>/now</a> page
      for what I'm currently up to.
    </p>
  </SectionPreview>
</Layout>
