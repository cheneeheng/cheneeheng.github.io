---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const current = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/research', label: 'Research' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/now', label: 'Now' },
  { href: '/blog', label: 'Blog' },
];

function isActive(href: string) {
  const full = (base + href).replace(/\/$/, '') || '/';
  return full === current;
}
---

<nav class="border-b border-zinc-200 dark:border-zinc-800">
  <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <ul class="flex flex-wrap items-center gap-x-1 gap-y-1 text-sm">
      {links.map((l) => (
        <li>
          <a
            href={base + l.href}
            class={`inline-flex items-center rounded-md px-2.5 py-1.5 transition-colors ${
              isActive(l.href)
                ? 'bg-zinc-900 text-white dark:bg-white dark:text-zinc-900'
                : 'text-zinc-600 dark:text-zinc-400 hover:bg-zinc-100 hover:text-zinc-900 dark:hover:bg-zinc-800 dark:hover:text-zinc-50'
            }`}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div
      role="radiogroup"
      aria-label="Color theme"
      class="theme-toggle inline-flex items-center rounded-md border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-0.5 shrink-0"
    >
      <button
        type="button"
        role="radio"
        aria-label="Light"
        data-theme-set="light"
        class="theme-btn inline-flex h-7 w-7 items-center justify-center rounded text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
      </button>
      <button
        type="button"
        role="radio"
        aria-label="System"
        data-theme-set="system"
        class="theme-btn inline-flex h-7 w-7 items-center justify-center rounded text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <rect x="3" y="4" width="18" height="13" rx="2"></rect>
          <path d="M8 21h8M12 17v4"></path>
        </svg>
      </button>
      <button
        type="button"
        role="radio"
        aria-label="Dark"
        data-theme-set="dark"
        class="theme-btn inline-flex h-7 w-7 items-center justify-center rounded text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const apply = (mode) => {
      const dark = mode === 'dark' || (mode === 'system' && matchMedia('(prefers-color-scheme: dark)').matches);
      root.classList.toggle('dark', dark);
      root.dataset.themeMode = mode;
      try { mode === 'system' ? localStorage.removeItem('theme') : localStorage.setItem('theme', mode); } catch {}
      paint();
    };
    const paint = () => {
      const mode = root.dataset.themeMode || 'system';
      document.querySelectorAll('.theme-btn').forEach((b) => {
        const isOn = b.dataset.themeSet === mode;
        b.setAttribute('aria-checked', isOn ? 'true' : 'false');
        b.classList.toggle('bg-zinc-900', isOn);
        b.classList.toggle('text-white', isOn);
        b.classList.toggle('dark:bg-white', isOn);
        b.classList.toggle('dark:text-zinc-900', isOn);
        b.classList.toggle('text-zinc-500', !isOn);
        b.classList.toggle('dark:text-zinc-400', !isOn);
      });
    };
    document.querySelectorAll('.theme-btn').forEach((b) => {
      b.addEventListener('click', () => apply(b.dataset.themeSet));
    });
    matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if ((root.dataset.themeMode || 'system') === 'system') apply('system');
    });
    paint();
  })();
</script>
