---
import type { Project } from '../data/projects';
interface Props {
  project: Project;
}
const { project } = Astro.props;

const statusClasses =
  project.status === 'active'
    ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-200'
    : 'bg-zinc-100 text-zinc-700 dark:bg-zinc-800 dark:text-zinc-200';
---

<article class="rounded-lg border border-zinc-200 dark:border-zinc-800 p-5 flex flex-col">
  <div class="flex flex-wrap items-center gap-2">
    <h3 class="text-lg font-semibold tracking-tight">{project.title}</h3>
    <span class={`text-xs rounded-full px-2 py-0.5 ${statusClasses}`}>
      {project.status}
    </span>
  </div>
  <ul class="mt-2 flex flex-wrap gap-2">
    {project.tags.map((t) => (
      <li class="text-xs rounded-full border border-zinc-200 dark:border-zinc-700 px-2 py-0.5 text-zinc-600 dark:text-zinc-300">
        {t}
      </li>
    ))}
  </ul>
  <p class="mt-3 text-zinc-700 dark:text-zinc-300 grow">{project.summary}</p>
  {project.link && (
    <a
      href={project.link}
      class="mt-3 inline-block text-sm font-medium underline underline-offset-4"
    >
      Visit →
    </a>
  )}
</article>
