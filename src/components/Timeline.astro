---
interface TimelineItem {
  years: string;
  title: string;
  body: string;
}

const items: TimelineItem[] = [
  {
    years: '2018 – 2023',
    title: 'PhD / Computer-vision research',
    body:
      'Published on traffic-junction understanding, optical flow, binary neural networks for traffic signs, and patient-monitoring models — working with RGB and RGB-D cameras, OpenCV, TensorFlow, and PyTorch.',
  },
  {
    years: '~5 years',
    title: 'Industry experience as student & PhD candidate',
    body:
      'Worked in industry alongside research — coordinating interdisciplinary projects, supervising student work, and getting hands-on with Python, C++, Kubernetes, and Docker.',
  },
  {
    years: 'Now',
    title: 'AI agents',
    body:
      'Focused on AI agents that edit code with discipline: minimal-diff edits, explicit authorization, and decisions that get logged rather than buried.',
  },
];
---

<section>
  <ol class="space-y-6 border-l border-zinc-200 dark:border-zinc-800 pl-6">
    {items.map((item) => (
      <li class="relative">
        <span class="absolute -left-[29px] top-1.5 h-2.5 w-2.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></span>
        <div class="text-sm text-zinc-500">{item.years}</div>
        <h3 class="text-lg font-semibold tracking-tight">{item.title}</h3>
        <p class="mt-1 text-zinc-700 dark:text-zinc-300">{item.body}</p>
      </li>
    ))}
  </ol>
</section>
