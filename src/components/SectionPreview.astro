---
interface Props {
  title: string;
  href: string;
  index?: string;
  eyebrow?: string;
}
const { title, href, index, eyebrow } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="mt-16 scroll-mt-20">
  <div class="flex items-end justify-between gap-4 border-b border-zinc-200 dark:border-zinc-800 pb-3">
    <div class="flex items-baseline gap-3">
      {index && (
        <span class="text-xs font-mono font-medium text-zinc-400 dark:text-zinc-500 tabular-nums">{index}</span>
      )}
      <div>
        {eyebrow && (
          <div class="text-[11px] uppercase tracking-[0.16em] text-zinc-500 dark:text-zinc-400">{eyebrow}</div>
        )}
        <h2 class="text-2xl font-semibold tracking-tight">{title}</h2>
      </div>
    </div>
    <a
      href={base + href}
      class="group inline-flex items-center gap-1 text-sm font-medium text-zinc-600 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-50"
    >
      View all
      <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
    </a>
  </div>
  <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
    <slot />
  </div>
</section>
