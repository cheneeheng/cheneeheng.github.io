---
import Layout from './Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { formatDate } from '../lib/date';

interface Props {
  frontmatter: {
    title: string;
    date?: string;
    description?: string;
    banner?: string;
    bannerAlt?: string;
    repo?: string;
  };
}

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const banner = frontmatter.banner ? base + frontmatter.banner : undefined;
const repo = frontmatter.repo;
const repoName = repo ? new URL(repo).pathname.replace(/^\/|\/$/g, '') : undefined;
---

<Layout title={`${frontmatter.title} — EE Heng Chen`} description={frontmatter.description}>
  <PageHeader title={frontmatter.title} subtitle={formatDate(frontmatter.date)} />
  {banner && (
    <img
      src={banner}
      alt={frontmatter.bannerAlt ?? `${frontmatter.title} — banner`}
      width="1200"
      height="300"
      loading="eager"
      class="mb-10 w-full rounded-xl border border-zinc-200 dark:border-zinc-800"
    />
  )}
  <article class="prose prose-zinc dark:prose-invert max-w-none leading-relaxed">
    <slot />
  </article>
  {repo && (
    <aside class="mt-12 flex items-center gap-3 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/50 px-5 py-4">
      <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true" class="shrink-0 fill-zinc-500 dark:fill-zinc-400">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
      </svg>
      <p class="text-sm text-zinc-600 dark:text-zinc-400">
        The project this post follows lives at
        <a href={repo} class="font-medium text-zinc-900 dark:text-zinc-100 underline underline-offset-4">{repoName}</a>
        on GitHub.
      </p>
    </aside>
  )}
</Layout>
